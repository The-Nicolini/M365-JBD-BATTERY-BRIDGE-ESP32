<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:text="⚠ Verify register addresses with JBD PC software before writing."
            android:textSize="12sp"
            android:textColor="#B00020"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Cell Overvoltage Protection -->
        <TextView android:text="Cell Overvoltage Protection (mV)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etCellOvp" android:hint="e.g. 4200"
                android:inputType="number" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteCellOvp" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Cell OVP Release -->
        <TextView android:text="Cell OVP Release (mV)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etCellOvpRel" android:hint="e.g. 4100"
                android:inputType="number" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteCellOvpRel" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Cell Undervoltage Protection -->
        <TextView android:text="Cell Undervoltage Protection (mV)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etCellUvp" android:hint="e.g. 2800"
                android:inputType="number" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteCellUvp" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Cell UVP Release -->
        <TextView android:text="Cell UVP Release (mV)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etCellUvpRel" android:hint="e.g. 3000"
                android:inputType="number" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteCellUvpRel" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Discharge OCP -->
        <TextView android:text="Discharge Overcurrent Protection (mA)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etDchgOcp" android:hint="e.g. 30000"
                android:inputType="number" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteDchgOcp" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Charge OCP -->
        <TextView android:text="Charge Overcurrent Protection (mA)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etChgOcp" android:hint="e.g. 10000"
                android:inputType="number" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteChgOcp" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- High Temp Protection -->
        <TextView android:text="High Temperature Protection (°C)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etHighTemp" android:hint="e.g. 60"
                android:inputType="numberSigned" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteHighTemp" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Low Temp Protection -->
        <TextView android:text="Low Temperature Protection (°C)" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <EditText android:id="@+id/etLowTemp" android:hint="e.g. -20"
                android:inputType="numberSigned" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnWriteLowTemp" android:text="Write"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- BMS Response -->
        <TextView android:text="BMS Response" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView
            android:id="@+id/tvCmdResponse"
            android:text="---"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_bg"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
